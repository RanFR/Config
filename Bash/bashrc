# Only run for interactive shells
[[ $- != *i* ]] && return

# XDG config directory
BASH_CONFIG_DIR="$HOME/.config/bash"

# Ensure predictable glob behavior
shopt -s nullglob

if [[ -d "$BASH_CONFIG_DIR" ]]; then
    for file in "$BASH_CONFIG_DIR"/[0-9][0-9]-*; do
        [[ -f "$file" && -r "$file" ]] && source "$file"
    done
else
    PS1='\u@\h:\w\$ '
    printf 'ERROR: Configuration directory not found: %s\n' "$BASH_CONFIG_DIR" >&2
fi

# Restore default glob behavior
shopt -u nullglob