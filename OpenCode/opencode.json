{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "model": "zhipuai-coding-plan/glm-5.1"
    },
    "compaction": {
      "model": "zhipuai-coding-plan/glm-4.5-air"
    },
    "explore": {
      "model": "zhipuai-coding-plan/glm-4.7"
    },
    "general": {
      "model": "zhipuai-coding-plan/glm-5-turbo"
    },
    "plan": {
      "model": "zhipuai-coding-plan/glm-5.1"
    },
    "scout": {
      "model": "zhipuai-coding-plan/glm-4.7"
    },
    "summary": {
      "model": "zhipuai-coding-plan/glm-4.5-air"
    },
    "title": {
      "model": "zhipuai-coding-plan/glm-4.5-air"
    }
  },
  "autoupdate": "notify",
  "default_agent": "build",
  "enabled_providers": [
    "deepseek",
    "zhipuai-coding-plan"
  ],
  "mcp": {
    "open-source-reader": {
      "headers": {
        "Authorization": "Bearer {env:ZHIPU_API_KEY}"
      },
      "type": "remote",
      "url": "https://open.bigmodel.cn/api/mcp/zread/mcp"
    },
    "vision": {
      "command": [
        "npx",
        "-y",
        "@z_ai/mcp-server"
      ],
      "environment": {
        "Z_AI_API_KEY": "{env:ZHIPU_API_KEY}",
        "Z_AI_MODE": "ZHIPU"
      },
      "type": "local"
    },
    "web-reader": {
      "headers": {
        "Authorization": "Bearer {env:ZHIPU_API_KEY}"
      },
      "type": "remote",
      "url": "https://open.bigmodel.cn/api/mcp/web_reader/mcp"
    },
    "web-search": {
      "headers": {
        "Authorization": "Bearer {env:ZHIPU_API_KEY}"
      },
      "type": "remote",
      "url": "https://open.bigmodel.cn/api/mcp/web_search_prime/mcp"
    }
  },
  "share": "disabled"
}
