{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "mcp": {
    "web-reader": {
      "headers": {
        "Authorization": "Bearer {env:Z_AI_API_KEY}"
      },
      "type": "remote",
      "url": "https://open.bigmodel.cn/api/mcp/web_reader/mcp"
    },
    "web-search-prime": {
      "headers": {
        "Authorization": "Bearer {env:Z_AI_API_KEY}"
      },
      "type": "remote",
      "url": "https://open.bigmodel.cn/api/mcp/web_search_prime/mcp"
    },
    "zai-mcp-server": {
      "command": [
        "npx",
        "-y",
        "@z_ai/mcp-server"
      ],
      "environment": {
        "Z_AI_MODE": "ZHIPU"
      },
      "type": "local"
    }
  },
  "share": "disabled"
}
